# Copy to .env and fill in. .env is gitignored — DO NOT commit it.

# ─── data sources ───
ETHERSCAN_KEY=your_etherscan_api_key_here
# ETH_RPC_URL=https://ethereum.publicnode.com

# ─── server ───
PORT=3000

# ─── x402 ───
# Wallet that receives USDC payments on the chosen network
PAYMENT_ADDRESS=0x0000000000000000000000000000000000000000
X402_NETWORK=base-sepolia
X402_PRICE=$0.001
X402_FACILITATOR_URL=https://x402.org/facilitator

# Private key the server uses to auto-pay for the dashboard's /demo/analyze
# proxy. Must be a base-sepolia wallet funded with test USDC.
# Faucet: https://faucet.circle.com/ (Base Sepolia, USDC)
# Leave blank to disable the dashboard demo proxy.
DEMO_PRIVATE_KEY=

# Private key the CLI uses with --paid. Same wallet rules.
PRIVATE_KEY=
